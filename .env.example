# Copy to .env.local and fill in with `supabase start`'s printed values
# (ADR-0008/0009). Never commit the real .env.local.
#
# The Google OAuth client used for local sign-in (ADR-0011) is separate —
# see supabase/.env.example and the README.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service-role key, only for RLS integration tests (`*.rls.test.ts`, #13) —
# never read by app code. `supabase start` also prints this value.
SUPABASE_SERVICE_ROLE_KEY=
